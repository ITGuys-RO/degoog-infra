# Copy to .env and fill in.
# .env is gitignored. Never commit real secrets.

# --- degoog-mcp ---
# Optional: 32-byte random token the MCP server requires on /mcp requests.
# Leave blank if an upstream gateway (Cloudflare Access OAuth, etc.) already
# gates /mcp; set to enforce bearer auth at the app layer (defense in depth
# or when Access isn't in front).
# Generate:
#   node -e "console.log(crypto.randomBytes(32).toString('base64url'))"
DEGOOG_MCP_BEARER=

# Default language passed to degoog when the caller omits it (ISO 639-1).
DEGOOG_DEFAULT_LANGUAGE=ro

# Per-request HTTP timeout in milliseconds.
DEGOOG_TIMEOUT_MS=15000

# --- cloudflared ---
# Cloudflare Zero Trust -> Networks -> Connectors -> Cloudflare Tunnels ->
# (your tunnel) -> install connector. Copy the eyJ... token from the install
# command Cloudflare shows you.
CLOUDFLARE_TUNNEL_TOKEN=
