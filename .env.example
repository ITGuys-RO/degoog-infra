# Copy to .env and fill in.
# .env is gitignored. Never commit real secrets.

# --- degoog-mcp ---
# Default language passed to degoog when the caller omits it (ISO 639-1).
DEGOOG_DEFAULT_LANGUAGE=ro

# Public base URL the MCP is reachable at through the tunnel. Required for
# serving RFC 9728 Protected Resource Metadata so MCP clients can discover
# the OAuth authorization server. Must match the Access app's public hostname.
MCP_PUBLIC_BASE_URL=https://degoog-mcp.itguys.ro

# OAuth authorization server issuer URL — Cloudflare Access's team domain.
# Verify the metadata endpoint works:
#   curl https://<team>.cloudflareaccess.com/.well-known/oauth-authorization-server
MCP_OAUTH_AUTHORIZATION_SERVER=https://itguys.cloudflareaccess.com

# Per-request HTTP timeout in milliseconds.
DEGOOG_TIMEOUT_MS=15000

# --- cloudflared ---
# Cloudflare Zero Trust -> Networks -> Connectors -> Cloudflare Tunnels ->
# (your tunnel) -> install connector. Copy the eyJ... token from the install
# command Cloudflare shows you.
CLOUDFLARE_TUNNEL_TOKEN=
