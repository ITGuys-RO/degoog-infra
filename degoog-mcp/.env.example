# URL of your degoog instance. For stdio (localhost) use http://degoog.local:4444.
DEGOOG_URL=http://degoog.local:4444

# Default language passed to degoog when the caller omits it (ISO 639-1).
DEGOOG_DEFAULT_LANGUAGE=ro

# HTTP timeout for both search and fetch, in milliseconds.
DEGOOG_TIMEOUT_MS=15000

# Log level: debug | info | warn | error
LOG_LEVEL=info
