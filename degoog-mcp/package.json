{
  "name": "degoog-mcp",
  "version": "0.1.0",
  "description": "MCP server that proxies web search and page extraction through a self-hosted degoog instance.",
  "license": "MIT",
  "author": "dustfeather <dustfeather@gmail.com>",
  "type": "module",
  "bin": {
    "degoog-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport http",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.2.0",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.6.2",
    "typescript": "^6.0.3"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "overrides": {
      "hono": ">=4.12.16",
      "ip-address": ">=10.1.1"
    }
  }
}
